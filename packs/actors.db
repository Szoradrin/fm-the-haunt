{"_id": "C4GdU1LRfDvFz7SQ", "name": "Gargoyle [MM Reference]", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"details": {"biography": {"value": "<p><strong>Source:</strong> MM p.140</p><p><strong>Compendium:</strong> dnd5e.monsters.gargoyle</p><p><strong>Location:</strong> Area 2 - The Foyer</p><p><strong>Notes:</strong> Animates when party crosses the line between the two statues. Fights to the death.</p><p><em>Import this creature from the dnd5e system compendium: dnd5e.monsters.gargoyle</em></p>"}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_gargoyle", "type": "mm_reference", "compendium_id": "dnd5e.monsters.gargoyle", "encounter_location": "Area 2 - The Foyer"}}}
{"_id": "iiaBYg8LbvNzRnz4", "name": "Beholder Zombie [MM Reference]", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"details": {"biography": {"value": "<p><strong>Source:</strong> MM p.316</p><p><strong>Compendium:</strong> dnd5e.monsters.beholder-zombie</p><p><strong>Location:</strong> Area 7 - Alfresco Area</p><p><strong>Notes:</strong> Rises from the pool when party comes within 5ft of poolside. Does not leave the alfresco area.</p><p><em>Import this creature from the dnd5e system compendium: dnd5e.monsters.beholder-zombie</em></p>"}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_beholder_zombie", "type": "mm_reference", "compendium_id": "dnd5e.monsters.beholder-zombie", "encounter_location": "Area 7 - Alfresco Area"}}}
{"_id": "GWN4Bkv4yvllCpNw", "name": "Cloaker [MM Reference]", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"details": {"biography": {"value": "<p><strong>Source:</strong> MM p.41</p><p><strong>Compendium:</strong> dnd5e.monsters.cloaker</p><p><strong>Location:</strong> Area 12 - The Library</p><p><strong>Notes:</strong> Disguised as a leather cloak on a coat stand. Surprises party if not detected (DC 16 INT Nature). Attacks until 5 HP remaining, then flees to surprise party again.</p><p><em>Import this creature from the dnd5e system compendium: dnd5e.monsters.cloaker</em></p>"}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_cloaker", "type": "mm_reference", "compendium_id": "dnd5e.monsters.cloaker", "encounter_location": "Area 12 - The Library"}}}
{"_id": "lOZWJYKi0EpOhgbT", "name": "Evil Doll", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"abilities": {"str": {"value": 7}, "dex": {"value": 18}, "con": {"value": 17}, "int": {"value": 8}, "wis": {"value": 10}, "cha": {"value": 16}}, "attributes": {"hp": {"value": 119, "max": 119, "formula": "14d10+42"}, "ac": {"value": 14}, "speed": {"value": "20 ft."}}, "details": {"biography": {"value": "<p><strong>Location:</strong> Second Floor - random (40% per room)</p><p>Appears 3 times on 2nd floor (40% chance per room). Escalating encounter behavior. Regenerates HP between encounters (show as twine/patch repairs).</p>"}, "alignment": "chaotic evil", "cr": 4.0, "type": {"value": "construct"}}, "traits": {"size": "tin", "di": {"value": ["poison"]}, "dr": {"value": ["piercing (nonmagical)", "slashing (nonmagical)"]}, "dv": {"value": ["fire"]}, "ci": {"value": ["charmed", "exhaustion", "frightened", "paralyzed", "poisoned", "unconscious"]}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_evil_doll", "source": "The Haunt PDF", "encounter_location": "Second Floor - random (40% per room)"}}}
{"_id": "SzFa2Rd9URYctcw0", "name": "Phase Spider [MM Reference]", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"details": {"biography": {"value": "<p><strong>Source:</strong> MM p.334</p><p><strong>Compendium:</strong> dnd5e.monsters.phase-spider</p><p><strong>Location:</strong> Area 17 - Guest Rooms</p><p><strong>Notes:</strong> Appear on even d20 roll when entering either guest room. Attack from above doorway.</p><p><em>Import this creature from the dnd5e system compendium: dnd5e.monsters.phase-spider</em></p>"}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_phase_spider", "type": "mm_reference", "compendium_id": "dnd5e.monsters.phase-spider", "encounter_location": "Area 17 - Guest Rooms"}}}
{"_id": "1piBD1QweRsJoBWY", "name": "Ghost (Washroom) [MM Reference]", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"details": {"biography": {"value": "<p><strong>Source:</strong> MM p.147</p><p><strong>Compendium:</strong> dnd5e.monsters.ghost</p><p><strong>Location:</strong> Area 19 - The Guests Wash Room</p><p><strong>Notes:</strong> Appears as a body in a bath tub. Only attacks if heroes try to interact or save it.</p><p><em>Import this creature from the dnd5e system compendium: dnd5e.monsters.ghost</em></p>"}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_ghost_washroom", "type": "mm_reference", "compendium_id": "dnd5e.monsters.ghost", "encounter_location": "Area 19 - The Guests Wash Room"}}}
{"_id": "4JfsMMysQDr0cqbj", "name": "Ghast [MM Reference]", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"details": {"biography": {"value": "<p><strong>Source:</strong> MM p.148</p><p><strong>Compendium:</strong> dnd5e.monsters.ghast</p><p><strong>Location:</strong> Area 20 - The Servant's Living Space</p><p><strong>Notes:</strong> Commands 2 ghouls. Door is locked (DC 15 Thieves Tools). Fight to the death.</p><p><em>Import this creature from the dnd5e system compendium: dnd5e.monsters.ghast</em></p>"}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_ghast", "type": "mm_reference", "compendium_id": "dnd5e.monsters.ghast", "encounter_location": "Area 20 - The Servant's Living Space"}}}
{"_id": "gkH7QeNV8dPIaGoU", "name": "Ghoul [MM Reference]", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"details": {"biography": {"value": "<p><strong>Source:</strong> MM p.148</p><p><strong>Compendium:</strong> dnd5e.monsters.ghoul</p><p><strong>Location:</strong> Area 20 - The Servant's Living Space</p><p><strong>Notes:</strong> Commanded by the Ghast. Fight to the death.</p><p><em>Import this creature from the dnd5e system compendium: dnd5e.monsters.ghoul</em></p>"}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_ghoul", "type": "mm_reference", "compendium_id": "dnd5e.monsters.ghoul", "encounter_location": "Area 20 - The Servant's Living Space"}}}
{"_id": "ixmtADYKxVi5AYHA", "name": "Gertrude, Night Hag", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"abilities": {"str": {"value": 18}, "dex": {"value": 15}, "con": {"value": 16}, "int": {"value": 16}, "wis": {"value": 14}, "cha": {"value": 16}}, "attributes": {"hp": {"value": 112, "max": 112, "formula": "15d8+45"}, "ac": {"value": 17}, "speed": {"value": "30 ft."}}, "details": {"biography": {"value": "<p><strong>Location:</strong> Area 24 - A General's Broken Heart</p><p>BBEG. Has been feeding off necrotic energy for a millennium. After defeat: shrivels to black ooze. Victim falls from ceiling, whispers 'thank you', disintegrates to ash leaving only the Leacher's Emerald.</p>"}, "alignment": "neutral evil", "cr": 5.0, "type": {"value": "fiend"}}, "traits": {"size": "med", "di": {"value": []}, "dr": {"value": ["cold", "fire", "bludgeoning (nonmagical/nonsilvered)", "piercing (nonmagical/nonsilvered)", "slashing (nonmagical/nonsilvered)"]}, "dv": {"value": []}, "ci": {"value": ["charmed"]}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_gertrude", "source": "The Haunt PDF", "encounter_location": "Area 24 - A General's Broken Heart"}}}
{"_id": "quR9fzYjKOVRBbEO", "name": "Incomplete Flesh Golem", "type": "npc", "img": "icons/svg/mystery-man.svg", "system": {"abilities": {"str": {"value": 10}, "dex": {"value": 10}, "con": {"value": 10}, "int": {"value": 10}, "wis": {"value": 10}, "cha": {"value": 10}}, "attributes": {"hp": {"value": 10, "max": 10, "formula": "10"}, "ac": {"value": 10}, "speed": {"value": "30 ft."}}, "details": {"biography": {"value": "<p><strong>Location:</strong> Area 15 - The Basement</p><p>Not an enemy. Puzzle NPC. Complete by attaching correct hands (4), feet (12), brain (50) from sequence puzzle. Then DC 15 Arcana to activate via crank/lightning. Opens locked door when complete.</p>"}, "alignment": "", "cr": 0, "type": {"value": "humanoid"}}, "traits": {"size": "med", "di": {"value": []}, "dr": {"value": []}, "dv": {"value": []}, "ci": {"value": []}}}, "items": [], "effects": [], "flags": {"questwright": {"id": "actor_flesh_golem_incomplete", "source": "The Haunt PDF", "encounter_location": "Area 15 - The Basement"}}}
